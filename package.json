{
  "name": "kafka",
  "version": "1.0.0",
  "description": "Kafka TypeScript example project",
  "main": "dist/index.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "body-parser": "^1.20.3",
    "express": "^4.18.2",
    "kafkajs": "^2.2.4"
  },
  "devDependencies": {
    "typescript": "^5.2.0",
    "ts-node-dev": "^2.0.0",
    "ts-node": "^10.9.1",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.17",
    "eslint": "^8.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "api": "ts-node src/server.ts",
    "produce": "ts-node src/send.ts",
    "lint": "eslint . --ext .ts",
    "test": "jest --runInBand",
    "docker:up": "docker-compose up -d",
